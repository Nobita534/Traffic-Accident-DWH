  <Source dwd:design-time-name="d0ef3ea3-5540-45a0-bf58-e01c6ad4f935">
    <DataSourceViewID>TRAFFIC ACCIDENT</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="5a7f7a0f-3cb6-492a-b66f-da7c5134a3e9">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;    
CREATE MEMBER CURRENTCUBE.[Measures].[Top Accident Month Name]
 AS Head(
    Order(
        [Dim Date Of Crash].[Crash Month].[Crash Month].Members,
        ([Measures].[FACT Accident Count], [Dim Date Of Crash].[Crash Year].&amp;[2023]),
        BDESC
    ),
    1
).Item(0).Name, 
VISIBLE = 1;     
CREATE MEMBER CURRENTCUBE.[Measures].[Top Accident Month Count]
 AS (
        [Dim Date Of Crash].[Crash Year].&amp;[2023],
        HEAD(
            ORDER(
                [Dim Date Of Crash].[Crash Month].[Crash Month].Members,
                ([Dim Date Of Crash].[Crash Year].&amp;[2023], [Measures].[FACT Accident Count]),
                DESC
            ),
            1
        ).Item(0),
        [Measures].[FACT Accident Count]
    ), 
VISIBLE = 1  ;      
CREATE MEMBER CURRENTCUBE.[Measures].[Intersection Accident Count]
 AS (
    [Measures].[FACT Accident Count],
    [Dim Traffic Condition].[Intersection Related I].[Y]
), 
VISIBLE = 1;       
CREATE MEMBER CURRENTCUBE.[Measures].[Rate of Fatal]
 AS DIVIDE(
    [Measures].[Injuries Fatal],
    [Measures].[Injuries Total]
), 
VISIBLE = 1;   
CREATE MEMBER CURRENTCUBE.[Measures].[Top Cause Name]
 AS IIF(
    IsEmpty([Measures].[Injuries Total]),
    NULL,
    Tail(
        TopCount(
            [Dim Cause].[Prim Contributory Cause].[Prim Contributory Cause].Members,
            1,
            ([Measures].[Injuries Total],[Dim Date Of Crash].[Crash Year].CurrentMember)
        )
    ).Item(0).Name
), 
VISIBLE = 1  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[Top Cause Injuries]
 AS IIF(
    IsEmpty([Measures].[Injuries Total]),
    NULL,
    (
        Tail(
            TopCount(
                [Dim Cause].[Prim Contributory Cause].[Prim Contributory Cause].Members,
                1,
                ([Measures].[Injuries Total],[Dim Date Of Crash].[Crash Year].CurrentMember)
            )
        ).Item(0),
        [Measures].[Injuries Total]
    )
), 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>